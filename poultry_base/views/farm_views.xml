<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Farm List View -->
        <record id="view_poultry_farm_list" model="ir.ui.view">
            <field name="name">poultry.farm.list</field>
            <field name="model">poultry.farm</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="farm_type"/>
                    <field name="size"/>
                    <field name="total_capacity"/>
                    <field name="location"/>
                </tree>
            </field>
        </record>

        <!-- Farm Form View -->
        <record id="view_poultry_farm_form" model="ir.ui.view">
            <field name="name">poultry.farm.form</field>
            <field name="model">poultry.farm</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="farm_type"/>
                                <field name="size"/>
                            </group>
                            <group>
                                <field name="total_capacity"/>
                                <field name="location"/>
                                <field name="phone"/>
                            </group>
                        </group>
                        <group>
                            <field name="email"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Farm Action -->
        <record id="action_poultry_farm" model="ir.actions.act_window">
            <field name="name">Farms</field>
            <field name="res_model">poultry.farm</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_poultry_farm_list"/>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_poultry_farm" name="Farms" action="action_poultry_farm" sequence="1"/>
    </data>
</odoo>