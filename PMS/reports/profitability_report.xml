<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Profitability Report by Flock -->
        <record id="poultry_profitability_report" model="ir.actions.report">
            <field name="name">Flock Profitability Report</field>
            <field name="model">poultry.flock</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">poultry_MS.report_flock_profitability</field>
            <field name="report_file">poultry_MS.report_flock_profitability</field>
        </record>

        <!-- Profitability Report Template -->
        <template id="report_flock_profitability">
            <t t-call="web.html_container">
                <div class="page">
                    <h2>Flock Profitability Analysis</h2>
                    
                    <t t-foreach="docs" t-as="flock">
                        <div class="page-break">
                            <h3><t t-out="flock.name"/></h3>
                            
                            <table class="table table-sm">
                                <tr>
                                    <td>Farm:</td>
                                    <td><t t-out="flock.farm_id.name"/></td>
                                </tr>
                                <tr>
                                    <td>Breed:</td>
                                    <td><t t-out="flock.breed"/></td>
                                </tr>
                                <tr>
                                    <td>Purpose:</td>
                                    <td><t t-out="flock.purpose"/></td>
                                </tr>
                                <tr>
                                    <td>Initial Birds:</td>
                                    <td><t t-out="flock.initial_bird_count"/></td>
                                </tr>
                                <tr>
                                    <td>Current Birds:</td>
                                    <td><t t-out="flock.bird_count"/></td>
                                </tr>
                                <tr>
                                    <td>Mortality:</td>
                                    <td><t t-out="flock.total_mortality"/></td>
                                </tr>
                            </table>

                            <h4>Financial Analysis</h4>
                            <table class="table table-sm">
                                <tr>
                                    <td>Total Feed Cost:</td>
                                    <td>��<t t-out="'{:,.2f}'.format(flock.total_feed_cost)"/></td>
                                </tr>
                                <t t-if="flock.total_eggs_produced > 0">
                                    <tr>
                                        <td>Total Eggs Produced:</td>
                                        <td><t t-out="flock.total_eggs_produced"/></td>
                                    </tr>
                                </t>
                            </table>
                        </div>
                    </t>
                </div>
            </t>
        </template>
    </data>
</odoo>
