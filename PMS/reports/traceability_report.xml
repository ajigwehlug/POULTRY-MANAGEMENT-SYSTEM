<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Traceability Report Template -->
        <record id="poultry_traceability_report" model="ir.actions.report">
            <field name="name">Product Traceability Report</field>
            <field name="model">stock.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">poultry_MS.report_product_traceability</field>
            <field name="report_file">poultry_MS.report_product_traceability</field>
        </record>

        <!-- Traceability Report Template -->
        <template id="report_product_traceability">
            <t t-call="web.html_container">
                <div class="page">
                    <h2>Product Traceability Report</h2>
                    
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Batch Number</th>
                                <th>Product</th>
                                <th>Source Flock</th>
                                <th>Production Date</th>
                                <th>Work Centers</th>
                                <th>Staff</th>
                                <th>Quality Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="move">
                                <tr>
                                    <td><t t-out="move.batch_number or 'N/A'"/></td>
                                    <td><t t-out="move.product_id.name"/></td>
                                    <td><t t-out="move.flock_id.name or 'N/A'"/></td>
                                    <td><t t-out="move.date_expected"/></td>
                                    <td><t t-out="move.workcenter_id.name or 'N/A'"/></td>
                                    <td>Multiple</td>
                                    <td>
                                        <t t-if="move.state == 'done'">
                                            <span class="badge badge-success">Completed</span>
                                        </t>
                                        <t t-else="">
                                            <span class="badge badge-warning">In Progress</span>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </template>
    </data>
</odoo>
