<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Work Centers for Poultry Processing -->
        
        <!-- Broiler Processing Line -->
        <record id="workcenter_slaughterhouse" model="mrp.workcenter">
            <field name="name">Slaughterhouse</field>
            <field name="capacity">100</field>
            <field name="poultry_process">slaughter</field>
            <field name="note">Stunning, killing, bleeding - Capacity: 100 birds/hour</field>
        </record>

        <record id="workcenter_plucking" model="mrp.workcenter">
            <field name="name">Plucking Station</field>
            <field name="capacity">60</field>
            <field name="poultry_process">plucking</field>
            <field name="note">Automatic feather plucking - Capacity: 60 birds/hour</field>
        </record>

        <record id="workcenter_evisceration" model="mrp.workcenter">
            <field name="name">Evisceration Line</field>
            <field name="capacity">40</field>
            <field name="poultry_process">evisceration</field>
            <field name="note">Remove organs and clean - Capacity: 40 birds/hour</field>
        </record>

        <record id="workcenter_cutting" model="mrp.workcenter">
            <field name="name">Cutting Station</field>
            <field name="capacity">50</field>
            <field name="poultry_process">cutting</field>
            <field name="note">Cut into parts - Capacity: 50 birds/hour</field>
        </record>

        <record id="workcenter_packaging" model="mrp.workcenter">
            <field name="name">Packaging Station</field>
            <field name="capacity">80</field>
            <field name="poultry_process">packaging</field>
            <field name="note">Vacuum packaging and labeling</field>
        </record>

        <!-- Egg Processing Line -->
        <record id="workcenter_egg_collection" model="mrp.workcenter">
            <field name="name">Egg Collection</field>
            <field name="capacity">10000</field>
            <field name="poultry_process">egg_collection</field>
            <field name="note">Collect eggs from nests - Capacity: 10,000 eggs/hour</field>
        </record>

        <record id="workcenter_egg_washing" model="mrp.workcenter">
            <field name="name">Egg Washing</field>
            <field name="capacity">5000</field>
            <field name="poultry_process">egg_washing</field>
            <field name="note">Automatic egg washer - Capacity: 5,000 eggs/hour</field>
        </record>

        <record id="workcenter_egg_grading" model="mrp.workcenter">
            <field name="name">Egg Grading & Sorting</field>
            <field name="capacity">3000</field>
            <field name="poultry_process">egg_grading</field>
            <field name="note">Automatic grader with manual verification - Capacity: 3,000 eggs/hour</field>
        </record>

        <record id="workcenter_egg_packaging" model="mrp.workcenter">
            <field name="name">Egg Packaging</field>
            <field name="capacity">1500</field>
            <field name="poultry_process">packaging</field>
            <field name="note">Pack into cartons - Capacity: 1,500 cartons/hour</field>
        </record>
    </data>
</odoo>