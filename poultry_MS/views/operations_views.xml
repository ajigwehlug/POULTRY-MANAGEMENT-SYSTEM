<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Operations List View -->
        <record id="view_poultry_operations_list" model="ir.ui.view">
            <field name="name">poultry.operations.list</field>
            <field name="model">poultry.operations</field>
            <field name="arch" type="xml">
                <list>
                    <field name="operation_date"/>
                    <field name="farm_id"/>
                    <field name="flock_id"/>
                    <field name="feed_consumed_kg"/>
                    <field name="feed_cost_total"/>
                    <field name="eggs_collected"/>
                    <field name="mortality_count"/>
                </list>
            </field>
        </record>

        <!-- Operations Form View -->
        <record id="view_poultry_operations_form" model="ir.ui.view">
            <field name="name">poultry.operations.form</field>
            <field name="model">poultry.operations</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <h1>
                            <field name="operation_date"/>
                        </h1>
                        <group>
                            <group>
                                <field name="farm_id" required="1"/>
                                <field name="flock_id" required="1"/>
                                <field name="work_center_id"/>
                                <field name="staff_on_duty"/>
                            </group>
                            <group>
                                <field name="journal_entry_id" readonly="1"/>
                                <field name="stock_move_id" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="feed" string="Feed &amp; Water">
                                <group>
                                    <group>
                                        <field name="feed_consumed_kg"/>
                                        <field name="feed_cost_per_kg"/>
                                        <field name="feed_cost_total"/>
                                    </group>
                                    <group>
                                        <field name="water_consumed_liters"/>
                                    </group>
                                </group>
                            </page>
                            <page name="health" string="Health">
                                <group>
                                    <group>
                                        <field name="mortality_count"/>
                                        <field name="sick_birds"/>
                                    </group>
                                </group>
                                <field name="treatment_notes"/>
                            </page>
                            <page name="production" string="Production">
                                <group>
                                    <group>
                                        <field name="eggs_collected"/>
                                        <field name="eggs_damaged"/>
                                        <field name="egg_grade_a"/>
                                        <field name="egg_grade_b"/>
                                    </group>
                                </group>
                            </page>
                            <page name="maintenance" string="Maintenance">
                                <group>
                                    <group>
                                        <field name="maintenance_done"/>
                                        <field name="cleaning_done"/>
                                    </group>
                                </group>
                                <field name="maintenance_notes"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Operations Actions -->
        <record id="action_poultry_operations" model="ir.actions.act_window">
            <field name="name">Daily Operations</field>
            <field name="res_model">poultry.operations</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
