<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Flock List View -->
        <record id="view_poultry_flock_list" model="ir.ui.view">
            <field name="name">poultry.flock.list</field>
            <field name="model">poultry.flock</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="farm_id"/>
                    <field name="breed"/>
                    <field name="purpose"/>
                    <field name="initial_bird_count"/>
                    <field name="bird_count"/>
                    <field name="age_in_weeks"/>
                    <field name="status"/>
                </list>
            </field>
        </record>

        <!-- Flock Form View -->
        <record id="view_poultry_flock_form" model="ir.ui.view">
            <field name="name">poultry.flock.form</field>
            <field name="model">poultry.flock</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_create_manufacturing_order" type="object" 
                                    class="oe_stat_button" icon="fa-cogs">
                                <span>Create MO</span>
                            </button>
                        </div>
                        <h1>
                            <field name="name" placeholder="Flock ID"/>
                        </h1>
                        <group>
                            <group>
                                <field name="farm_id" required="1"/>
                                <field name="breed" required="1"/>
                                <field name="purpose" required="1"/>
                            </group>
                            <group>
                                <field name="start_date" required="1"/>
                                <field name="age_in_weeks"/>
                                <field name="status"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="initial_bird_count" required="1"/>
                                <field name="bird_count"/>
                                <field name="expected_end_date"/>
                            </group>
                            <group>
                                <field name="total_eggs_produced"/>
                                <field name="total_mortality"/>
                                <field name="total_feed_consumed"/>
                                <field name="total_feed_cost"/>
                            </group>
                        </group>
                        
                        <group>
                            <field name="stock_location_id"/>
                        </group>
                        
                        <notebook>
                            <page name="operations" string="Daily Operations">
                                <field name="operation_ids">
                                    <list editable="bottom">
                                        <field name="operation_date"/>
                                        <field name="feed_consumed_kg"/>
                                        <field name="water_consumed_liters"/>
                                        <field name="mortality_count"/>
                                        <field name="eggs_collected"/>
                                    </list>
                                </field>
                            </page>
                            
                            <page name="manufacturing" string="Manufacturing Orders">
                                <field name="manufacturing_order_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="product_id"/>
                                        <field name="product_qty"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Flock Actions -->
        <record id="action_poultry_flock" model="ir.actions.act_window">
            <field name="name">Flocks</field>
            <field name="res_model">poultry.flock</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
