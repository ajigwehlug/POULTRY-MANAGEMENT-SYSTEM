<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Farm List View -->
        <record id="view_poultry_farm_list" model="ir.ui.view">
            <field name="name">poultry.farm.list</field>
            <field name="model">poultry.farm</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="manager_id"/>
                    <field name="scale"/>
                    <field name="location"/>
                    <field name="total_capacity"/>
                    <field name="current_bird_count"/>
                    <field name="is_active"/>
                </list>
            </field>
        </record>

        <!-- Farm Form View -->
        <record id="view_poultry_farm_form" model="ir.ui.view">
            <field name="name">poultry.farm.form</field>
            <field name="model">poultry.farm</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_flocks" type="object" class="oe_stat_button" icon="fa-cubes">
                                <field name="flock_ids" widget="statinfo"/>
                            </button>
                        </div>
                        <h1>
                            <field name="name" placeholder="Farm Name"/>
                        </h1>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="scale"/>
                                <field name="location"/>
                                <field name="region"/>
                            </group>
                            <group>
                                <field name="total_capacity"/>
                                <field name="current_bird_count"/>
                                <field name="is_active"/>
                            </group>
                        </group>
                        
                        <group string="Management">
                            <group>
                                <field name="manager_id" required="1"/>
                                <field name="main_contact_id"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page name="flocks" string="Flocks">
                                <field name="flock_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="breed"/>
                                        <field name="purpose"/>
                                        <field name="initial_bird_count"/>
                                        <field name="status"/>
                                    </list>
                                </field>
                            </page>
                            
                            <page name="locations" string="Farm Locations">
                                <field name="location_ids">
                                    <list>
                                        <field name="name"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Farm Actions -->
        <record id="action_poultry_farm" model="ir.actions.act_window">
            <field name="name">Farms</field>
            <field name="res_model">poultry.farm</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first farm!
                </p>
            </field>
        </record>
    </data>
</odoo>
